      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst inputData = $('准备请求').first().json;\n\nlet result = '';\nlet success = false;\n\nif (response.response) {\n  result = response.response;\n  success = true;\n}\nelse if (response.choices && response.choices[0]) {\n  result = response.choices[0].message?.content || '';\n  success = !!result;\n}\n\nreturn {\n  json: {\n    success: success,\n    provider: inputData.provider,\n    model: inputData.model,\n    auto_selected: inputData.auto_selected,\n    task_type: inputData.task_type,\n    content_length: inputData.content_length,\n    result: result,\n    url: inputData.url,\n    callback_url: inputData.callback_url,\n    error: success ? null : (response.error?.message || '调用失败')\n  }\n};"
      },

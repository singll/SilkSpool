    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst body = input.body || input;\n\nif (!body.content && !body.url) {\n  throw new Error('content 或 url 参数不能为空');\n}\n\nconst contentLength = (body.content || '').length;\nconst LONG_TEXT_THRESHOLD = 8000;\n\nlet provider = body.provider;\nlet autoSelected = false;\n\nif (!provider) {\n  if (body.local_only || body.sensitive) {\n    provider = 'ollama';\n  } else if (contentLength > LONG_TEXT_THRESHOLD) {\n    provider = 'kimi';\n  } else {\n    provider = 'deepseek';\n  }\n  autoSelected = true;\n}\n\nconst models = {\n  'ollama': 'qwen2.5:7b',\n  'deepseek': 'deepseek-chat',\n  'kimi': 'moonshot-v1-128k'\n};\n\nconst taskType = body.task_type || 'summarize';\nconst prompts = {\n  'summarize': `请用中文总结以下文章的核心内容：\\n\\n## 一句话总结\\n[简洁概括，不超过50字]\\n\\n## 关键要点\\n1. [要点1]\\n2. [要点2]\\n3. [要点3]\\n\\n## 技术标签\\n[用逗号分隔的相关标签]\\n\\n---\\n文章内容：\\n`,\n  'extract_tags': `请从以下内容中提取10-20个相关的技术标签，用逗号分隔，直接输出标签不要其他解释：\\n\\n`,\n  'security_analysis': `请从网络安全角度分析以下内容：\\n\\n## 安全要点\\n[涉及的安全概念]\\n\\n## 攻防技术\\n[详细说明]\\n\\n## 实践建议\\n[可操作建议]\\n\\n---\\n内容：\\n`\n};\n\nconst prompt = body.prompt || ((prompts[taskType] || prompts['summarize']) + (body.content || ''));\n\nreturn {\n  json: {\n    content: body.content,\n    content_length: contentLength,\n    url: body.url,\n    provider: provider,\n    auto_selected: autoSelected,\n    model: body.model || models[provider],\n    task_type: taskType,\n    prompt: prompt,\n    callback_url: body.callback_url\n  }\n};"
      },

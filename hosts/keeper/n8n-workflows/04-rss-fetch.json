      "id": "a1b2c3d4-0001-4000-a000-000000000005",
      "name": "\u62c9\u53d6RSS Feed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [960, 400],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// \u89e3\u6790RSS XML\u54cd\u5e94\uff0c\u63d0\u53d6\u6587\u7ae0\u5217\u8868\nconst input = $input.first().json;\nconst xml = input.data || input.body || '';\n\nif (!xml || typeof xml !== 'string') {\n  return [{ json: { articles: [], error: 'Empty or invalid response', sourceName: $('\\u9010\\u4e2a\\u5904\\u7406RSS\\u6e90').first().json.name } }];\n}\n\n// \u4ece\u4e0a\u6e38SplitInBatches\u83b7\u53d6\u6e90\u4fe1\u606f\nconst source = $('\\u9010\\u4e2a\\u5904\\u7406RSS\\u6e90').first().json;\n\nconst articles = [];\n\n// \u7528\u6b63\u5219\u63d0\u53d6<item>\u6216<entry>\u5143\u7d20\nconst itemRegex = /<item[^>]*>([\\s\\S]*?)<\\/item>/gi;\nconst entryRegex = /<entry[^>]*>([\\s\\S]*?)<\\/entry>/gi;\n\nfunction extractTag(content, tag) {\n  // \u652f\u6301CDATA\u548c\u666e\u901a\u6587\u672c\n  const cdataRegex = new RegExp(`<${tag}[^>]*><!\\\\[CDATA\\\\[([\\\\s\\\\S]*?)\\\\]\\\\]><\\\\/${tag}>`, 'i');\n  const plainRegex = new RegExp(`<${tag}[^>]*>([\\\\s\\\\S]*?)<\\\\/${tag}>`, 'i');\n  const hrefRegex = new RegExp(`<${tag}[^>]*href=[\"']([^\"']+)[\"']`, 'i');\n  \n  let match = content.match(cdataRegex);\n  if (match) return match[1].trim();\n  \n  match = content.match(plainRegex);\n  if (match) return match[1].trim();\n  \n  // Atom feed\u7684link\u53ef\u80fd\u662f<link href=\"...\"/>\n  if (tag === 'link') {\n    match = content.match(hrefRegex);\n    if (match) return match[1].trim();\n  }\n  \n  return '';\n}\n\nlet matches;\nconst regex = xml.includes('<entry') ? entryRegex : itemRegex;\n\nwhile ((matches = regex.exec(xml)) !== null) {\n  const itemXml = matches[1];\n  const title = extractTag(itemXml, 'title');\n  const link = extractTag(itemXml, 'link');\n  const pubDate = extractTag(itemXml, 'pubDate') || extractTag(itemXml, 'published') || extractTag(itemXml, 'updated');\n  \n  if (title && link) {\n    articles.push({\n      title: title,\n      link: link,\n      pubDate: pubDate\n    });\n  }\n}\n\n// \u8fd4\u56de\u6bcf\u7bc7\u6587\u7ae0\u4f5c\u4e3a\u5355\u72ec\u7684item\nif (articles.length === 0) {\n  return [{ json: { skip: true, sourceName: source.name, reason: 'no articles found' } }];\n}\n\nreturn articles.map(article => ({\n  json: {\n    url: article.link,\n    title: article.title,\n    pubDate: article.pubDate,\n    tags: source.tags,\n    category: source.category,\n    sourceName: source.name\n  }\n}));"
      },

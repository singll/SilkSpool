      "id": "a1b2c3d4-0001-4000-a000-000000000002",
      "name": "\u83b7\u53d6RSS\u6e90\u5217\u8868",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "// \u4eceBellkeeper API\u54cd\u5e94\u4e2d\u63d0\u53d6RSS\u6e90\u5e76\u6784\u5efaURL\nconst response = $input.first().json;\nconst sources = response.data || response.items || response;\n\nconst results = [];\nfor (const source of sources) {\n  let feedUrl = source.url;\n  // \u5982\u679curl\u4ee5/\u5f00\u5934\uff0c\u524d\u7f00\u52a0\u4e0arsshub\u5730\u5740\n  if (feedUrl.startsWith('/')) {\n    feedUrl = 'http://rsshub:1200' + feedUrl;\n  }\n\n  // \u63d0\u53d6\u6807\u7b7e\u540d\u79f0\uff08\u6807\u7b7e\u53ef\u80fd\u662f\u5bf9\u8c61\u6216\u5b57\u7b26\u4e32\uff09\n  const sourceTags = (source.tags || []).map(t => typeof t === 'object' ? (t.name || '') : String(t)).filter(t => t);\n\n  // \u5c06\u5206\u7c7b\u81ea\u52a8\u52a0\u5165\u6807\u7b7e\uff0c\u786e\u4fdd\u6bcf\u7bc7\u6587\u7ae0\u81f3\u5c11\u6709\u5206\u7c7b\u6807\u7b7e\n  if (source.category && !sourceTags.includes(source.category)) {\n    sourceTags.push(source.category);\n  }\n\n  results.push({\n    json: {\n      id: source.id,\n      name: source.name,\n      feedUrl: feedUrl,\n      originalUrl: source.url,\n      category: source.category || '',\n      tags: sourceTags,\n      isActive: source.is_active\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "a1b2c3d4-0001-4000-a000-000000000003",

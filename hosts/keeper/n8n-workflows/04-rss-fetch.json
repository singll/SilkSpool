    {
      "parameters": {
        "jsCode": "// \u5408\u5e76\u591a\u7bc7\u6587\u7ae0\u7684\u5904\u7406\u7ed3\u679c\u4e3a1\u4e2aitem\uff0c\u907f\u514dSplitInBatches\u88ab\u591a\u6b21\u89e6\u53d1\nconst items = $input.all();\nreturn [{ json: { articlesProcessed: items.length } }];"
      },
      "id": "a1b2c3d4-0001-4000-a000-000000000014",
      "name": "\u5408\u5e76\u5faa\u73af",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1920, 300]
    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst hour = now.getHours();\nlet period = '\u65e9\u95f4';\nif (hour >= 11 && hour < 15) period = '\u5348\u95f4';\nelse if (hour >= 17) period = '\u665a\u95f4';\n\nlet sourceCount = 0;\ntry {\n  sourceCount = $('\u63d0\u53d6RSS\u6e90').all().length;\n} catch(e) {}\n\nconst dateStr = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`;\nconst timeStr = `${String(hour).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`;\n\nconst summary = `\ud83d\udcf0 ${period}RSS\u5b9a\u65f6\u91c7\u96c6\u5df2\u5b8c\u6210\\n\u23f0 ${dateStr} ${timeStr}\\n\ud83d\udcca \u5904\u7406RSS\u6e90: ${sourceCount} \u4e2a`;\n\nreturn [{\n  json: {\n    summary: summary,\n    timestamp: now.toISOString()\n  }\n}];"
      },

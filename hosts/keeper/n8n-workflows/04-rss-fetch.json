    {
      "parameters": {
        "jsCode": "// \u6c47\u603b\u7edf\u8ba1\u4fe1\u606f\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.stats) {\n  staticData.stats = {};\n}\n\nconst items = $input.all();\nlet totalProcessed = 0;\nlet totalErrors = 0;\n\nfor (const item of items) {\n  const sourceName = item.json.sourceName || 'unknown';\n  if (!staticData.stats[sourceName]) {\n    staticData.stats[sourceName] = { processed: 0, errors: 0 };\n  }\n  if (item.json.error) {\n    staticData.stats[sourceName].errors++;\n    totalErrors++;\n  } else {\n    staticData.stats[sourceName].processed++;\n    totalProcessed++;\n  }\n}\n\nreturn [{\n  json: {\n    summary: `RSS\u91c7\u96c6\u5b8c\u6210: \u5904\u7406 ${totalProcessed} \u7bc7\u6587\u7ae0, ${totalErrors} \u4e2a\u9519\u8bef`,\n    totalProcessed,\n    totalErrors,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },

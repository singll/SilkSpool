        [{ "node": "返回帮助", "type": "main", "index": 0 }],
        [{ "node": "未知指令响应", "type": "main", "index": 0 }]
      ]
    },
    "准备问答请求": {
      "main": [[{ "node": "调用RAGFlow Chat", "type": "main", "index": 0 }]]
    },
    "调用RAGFlow Chat": {
      "main": [[{ "node": "格式化问答回复", "type": "main", "index": 0 }]]
    },
    "格式化问答回复": {
      "main": [[{ "node": "返回问答结果", "type": "main", "index": 0 }]]
    },
    "准备搜索请求": {
      "main": [[{ "node": "调用RAGFlow检索", "type": "main", "index": 0 }]]
    },
    "调用RAGFlow检索": {
      "main": [[{ "node": "格式化搜索回复", "type": "main", "index": 0 }]]
    },
    "格式化搜索回复": {
      "main": [[{ "node": "返回搜索结果", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
  "staticData": null,
  "pinData": {},

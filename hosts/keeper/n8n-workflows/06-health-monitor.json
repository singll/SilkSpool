    {
      "parameters": {
        "jsCode": "// \u5b9a\u4e49\u8981\u76d1\u63a7\u7684\u670d\u52a1\u7aef\u70b9\nreturn [\n  {\n    json: {\n      name: 'Bellkeeper',\n      url: `${$env.BELLKEEPER_URL}/api/health/detailed`,\n      needsApiKey: true,\n      apiKey: $env.BELLKEEPER_API_KEY\n    }\n  },\n  {\n    json: {\n      name: 'Firecrawl',\n      url: `${$env.FIRECRAWL_API_URL}/`,\n      needsApiKey: false\n    }\n  },\n  {\n    json: {\n      name: 'RSSHub',\n      url: 'http://rsshub:1200/',\n      needsApiKey: false\n    }\n  },\n  {\n    json: {\n      name: 'Memos',\n      url: 'http://memos:5230/api/v1/status',\n      needsApiKey: false\n    }\n  }\n];"
      },
      "id": "c3d4e5f6-0003-4000-c000-000000000002",

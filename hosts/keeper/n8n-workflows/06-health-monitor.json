      "id": "c3d4e5f6-0003-4000-c000-000000000006",
      "name": "\u68c0\u67e5Memos",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 580],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// \u6c47\u603b\u6240\u6709\u5065\u5eb7\u68c0\u67e5\u7ed3\u679c\uff0c\u4e0e\u4e0a\u6b21\u72b6\u6001\u5bf9\u6bd4\nconst staticData = $getWorkflowStaticData('global');\n\nconst bellkeeperResult = $('\\u68c0\\u67e5Bellkeeper').first().json;\nconst firecrawlResult = $('\\u68c0\\u67e5Firecrawl').first().json;\nconst rsshubResult = $('\\u68c0\\u67e5RSSHub').first().json;\nconst memosResult = $('\\u68c0\\u67e5Memos').first().json;\n\nfunction isHealthy(result, serviceName) {\n  // \u5982\u679c\u8bf7\u6c42\u5931\u8d25\uff0ccontinueOnFail\u4f1a\u8fd4\u56de\u5305\u542berror\u5b57\u6bb5\u7684\u5bf9\u8c61\n  if (!result || result.error || result.errorMessage) {\n    return false;\n  }\n  // Bellkeeper\u8fd4\u56de\u7684\u5065\u5eb7\u68c0\u67e5\u6709\u7279\u5b9a\u683c\u5f0f\n  if (serviceName === 'Bellkeeper') {\n    return result.status === 'healthy' || result.status === 'ok' || !!result.version;\n  }\n  // \u5176\u4ed6\u670d\u52a1\u53ea\u8981\u80fd\u54cd\u5e94\u5c31\u7b97\u5065\u5eb7\n  return true;\n}\n\nconst currentState = {\n  Bellkeeper: isHealthy(bellkeeperResult, 'Bellkeeper'),\n  Firecrawl: isHealthy(firecrawlResult, 'Firecrawl'),\n  RSSHub: isHealthy(rsshubResult, 'RSSHub'),\n  Memos: isHealthy(memosResult, 'Memos')\n};\n\nconst previousState = staticData.serviceState || null;\nconst changes = [];\n\nif (previousState) {\n  for (const [service, isUp] of Object.entries(currentState)) {\n    const wasUp = previousState[service];\n    if (wasUp !== undefined && wasUp !== isUp) {\n      if (isUp) {\n        changes.push(`\\u2705 ${service} \\u5df2\\u6062\\u590d\\u6b63\\u5e38`);\n      } else {\n        changes.push(`\\u274c ${service} \\u5df2\\u5b95\\u673a`);\n      }\n    }\n  }\n}\n\n// \u4fdd\u5b58\u5f53\u524d\u72b6\u6001\nstaticData.serviceState = currentState;\nstaticData.lastCheck = new Date().toISOString();\n\n// \u6784\u5efa\u901a\u77e5\u6d88\u606f\nlet hasChanges = changes.length > 0;\nlet message = '';\nlet html = '';\n\nif (hasChanges) {\n  const statusLines = Object.entries(currentState).map(\n    ([service, isUp]) => `${isUp ? '\\u2705' : '\\u274c'} ${service}: ${isUp ? '\\u6b63\\u5e38' : '\\u5f02\\u5e38'}`\n  );\n  \n  message = `\\u26a0\\ufe0f \\u670d\\u52a1\\u72b6\\u6001\\u53d8\\u66f4\\n\\n\\u53d8\\u66f4:\\n${changes.join('\\n')}\\n\\n\\u5f53\\u524d\\u72b6\\u6001:\\n${statusLines.join('\\n')}\\n\\n\\u68c0\\u67e5\\u65f6\\u95f4: ${new Date().toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai' })}`;\n  \n  html = `<h4>\\u26a0\\ufe0f \\u670d\\u52a1\\u72b6\\u6001\\u53d8\\u66f4</h4><p><b>\\u53d8\\u66f4:</b></p><ul>${changes.map(c => `<li>${c}</li>`).join('')}</ul><p><b>\\u5f53\\u524d\\u72b6\\u6001:</b></p><ul>${statusLines.map(s => `<li>${s}</li>`).join('')}</ul><p><small>\\u68c0\\u67e5\\u65f6\\u95f4: ${new Date().toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai' })}</small></p>`;\n}\n\nreturn [{\n  json: {\n    hasChanges: hasChanges,\n    changes: changes,\n    currentState: currentState,\n    previousState: previousState,\n    message: message,\n    html: html,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
